#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
set -e

bashio::log.info "Starting Replicarr..."

# Read add-on options
export LOG_LEVEL="$(bashio::config 'log_level' 'info')"

# Write config-defined instances to a temp file for the app to merge on startup
bashio::config 'instances' > /tmp/config_instances.json 2>/dev/null || echo '[]' > /tmp/config_instances.json

bashio::log.info "Log level: ${LOG_LEVEL}"

exec uvicorn main:app \
    --host 0.0.0.0 \
    --port 8099 \
    --app-dir /app \
    --log-level "${LOG_LEVEL}"
